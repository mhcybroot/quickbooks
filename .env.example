# Server
PORT=8090

# Database
DB_URL=jdbc:postgresql://localhost:5432/quickbooks_importer
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# App login
APP_USERNAME=admin
APP_PASSWORD=change_me

# Public/legal metadata
APP_PUBLIC_BASE_URL=https://qb.skylinkltd.ai
APP_PUBLIC_COMPANY_NAME=FINARA PROPERTY SOLUTIONS
APP_PUBLIC_SUPPORT_EMAIL=finarapropertysolutions@gmail.com

# QuickBooks OAuth (required)
QB_CLIENT_ID=your_quickbooks_client_id
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=https://qb.skylinkltd.ai/oauth/quickbooks/callback

# QuickBooks API endpoints/env
QB_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QB_AUTH_URL=https://appcenter.intuit.com/connect/oauth2
QB_TOKEN_URL=https://oauth.platform.intuit.com/oauth2/v1/tokens/bearer
QB_ENVIRONMENT=sandbox

# Import defaults
QB_SERVICE_ITEM_INCOME_ACCOUNT_ID=1
